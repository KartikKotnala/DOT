DB_PASSWORD=
DB_NAME=kiosk_db

# Email Service Config (Gmail App Password)


const nodemailer = require('nodemailer');

// Setup Nodemailer Transporter
const transporter = nodemailer.createTransport({
  service: 'gmail',
  auth: {
    user: process.env.EMAIL_USER,
    pass: process.env.EMAIL_PASS
  }
});

// Store OTPs temporarily in memory (or store in MySQL)
const loginOtps = new Map(); // key: email, value: { otp, expiresAt }

// 1. STEP 1: Verify Email Exists & Send 2FA Login OTP
app.post('/api/auth/send-login-otp', async (req, res) => {
  const { email } = req.body;
  if (!email) return res.status(400).json({ error: 'Email is required' });

  try {
    // Check if user exists in database
    const [users] = await db.query('SELECT * FROM users WHERE email = ?', [email]);
    if (users.length === 0) {
      return res.status(404).json({ error: 'No account found with this email' });
    }

    // Generate 6-digit OTP
    const otp = Math.floor(100000 + Math.random() * 900000).toString();
    const expiresAt = Date.now() + 3 * 60 * 1000; // 3 minutes

    loginOtps.set(email, { otp, expiresAt });

    // Send Email
    await transporter.sendMail({
      from: `"District7 Portal" <${process.env.EMAIL_USER}>`,
      to: email,
      subject: 'Your 2-Step Verification Login Code',
      html: `
        <div style="font-family: sans-serif; padding: 20px; background-color: #0d1322; color: #ffffff; border-radius: 12px;">
          <h2 style="color: #3b82f6;">Kiosk Management Portal</h2>
          <p>Your 2-Step Verification code is:</p>
          <h1 style="color: #10b981; letter-spacing: 4px;">${otp}</h1>
          <p style="color: #94a3b8; font-size: 12px;">This code will expire in 3 minutes.</p>
        </div>
      `
    });

    res.json({ success: true, message: '2FA code sent to email' });
  } catch (err) {
    console.error('Failed to send login OTP:', err);
    res.status(500).json({ error: 'Failed to send security code' });
  }
});

// 2. STEP 2: Verify Password & 2FA Login OTP
app.post('/api/auth/login-with-otp', async (req, res) => {
  const { email, password, otp } = req.body;

  try {
    // Check stored OTP
    const record = loginOtps.get(email);
    if (!record || record.otp !== otp || Date.now() > record.expiresAt) {
      return res.status(400).json({ error: 'Invalid or expired OTP code' });
    }

    // Check User & Password
    const [users] = await db.query('SELECT * FROM users WHERE email = ?', [email]);
    if (users.length === 0) return res.status(400).json({ error: 'Invalid credentials' });

    const user = users[0];
    
    // Validate Password (replace with bcrypt.compare if using hashed passwords)
    if (user.password !== password) {
      return res.status(400).json({ error: 'Incorrect password' });
    }

    // Clean up used OTP
    loginOtps.delete(email);

    // Return logged-in user
    res.json({
      success: true,
      user: { id: user.id, name: user.name, email: user.email, role: user.role }
    });
  } catch (err) {
    console.error('Login failed:', err);
    res.status(500).json({ error: 'Authentication failed' });
  }
});